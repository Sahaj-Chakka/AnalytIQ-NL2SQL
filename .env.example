# ─────────────────────────────────────────────────────────────────────────────
# AnalytIQ — Environment Variables
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (at least one is required) ───────────────────────────────────────────
# AnalytIQ prefers Anthropic Claude when both keys are present.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Vector Store ─────────────────────────────────────────────────────────────
# Path where ChromaDB persists embeddings.
# Change to a cloud path if using Pinecone (see docs/pinecone_setup.md).
CHROMA_PATH=./chroma_store

# ── Frontend → Backend URL ────────────────────────────────────────────────────
# URL the Streamlit app uses to reach the FastAPI backend.
ANALYTIQ_API_URL=http://localhost:8000

# ── Optional: Pinecone (alternative to ChromaDB) ─────────────────────────────
# PINECONE_API_KEY=your_pinecone_key_here
# PINECONE_ENV=us-east-1-aws
# PINECONE_INDEX=analytiq-schemas
